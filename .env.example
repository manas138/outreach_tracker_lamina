# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ---- Gmail OAuth (from Google Cloud Console) ----
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
GOOGLE_REFRESH_TOKEN=1//xxx

# ---- Campaign config ----
# Gmail search query. Supports all Gmail operators.
OUTREACH_QUERY=in:sent subject:"Shopify x Creative Magic"

# The sender address used to classify who is "us" in threads
OUTREACH_SENDER=manas@getmason.io

# Max threads to fetch per refresh (max 500 per call)
OUTREACH_MAX_THREADS=500

# ---- Vercel Cron security ----
# Random string. Vercel sends this as Authorization: Bearer <CRON_SECRET>
CRON_SECRET=generate_a_random_string_here
